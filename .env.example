# Shopify MCP Server Configuration
# Required: Your Shopify store domain (without https://)
SHOPIFY_STORE_DOMAIN=mystore.myshopify.com

# Required: Admin API access token (starts with shpat_)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Override API version (default: 2024-01)
# SHOPIFY_API_VERSION=2024-01

# Optional: Transport mode (default: stdio)
# MCP_TRANSPORT=http
# MCP_HTTP_PORT=3000
